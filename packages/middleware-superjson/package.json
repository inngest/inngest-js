{
  "name": "@inngest/middleware-superjson",
  "version": "0.1.0",
  "description": "SuperJSON serialization middleware for Inngest. Preserves Date, RegExp, and custom types through Inngest's data pipeline.",
  "main": "./index.js",
  "types": "./index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "build": "pnpm run build:clean && pnpm run build:tsc && pnpm run build:copy",
    "build:clean": "rm -rf ./dist",
    "build:tsc": "tsc --project tsconfig.build.json",
    "build:copy": "cp package.json LICENSE.md README.md dist",
    "postversion": "pnpm run build",
    "release": "cross-env DIST_DIR=dist node ../../scripts/release/publish.js",
    "pack": "pnpm run build && cd dist && pnpm pack --out ../inngest-middleware-superjson.tgz"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "import": "./index.js"
    }
  },
  "keywords": [
    "inngest-middleware",
    "inngest",
    "middleware",
    "superjson",
    "serialization",
    "date",
    "regexp"
  ],
  "homepage": "https://github.com/inngest/inngest-js/tree/main/packages/middleware-superjson#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inngest/inngest-js.git",
    "directory": "packages/middleware-superjson"
  },
  "author": "Inngest Inc. <hello@inngest.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@inngest/test-harness": "workspace:*",
    "inngest": "^4.0.0",
    "typescript": "~5.5.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "superjson": "^2.2.2"
  },
  "peerDependencies": {
    "inngest": ">=4.0.0 <5.0.0"
  }
}
